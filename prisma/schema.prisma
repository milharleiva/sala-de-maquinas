generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  VIEWER
}

model Cliente {
  id              String   @id @default(cuid())
  rut             String
  nombreCompleto  String
  fechaIngreso    DateTime
  horario         String   @default("") // Mantenido por compatibilidad
  horariosPorDia  Json     @default("{}") // { "Lunes": "17:30-18:30", "Martes": "19:00-20:00" }
  diasSemana      String[]
  valorMensual    Decimal  @db.Decimal(10, 2)
  estado          EstadoCliente @default(ACTIVO)
  ultimoPago      DateTime?
  nota            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("clientes")
}

model Pago {
  id              String   @id @default(cuid())
  clienteId       String
  nombre          String
  monto           Decimal  @db.Decimal(10, 2)
  fechaPago       DateTime @default(now())
  mes             Int
  ano             Int
  createdAt       DateTime @default(now())

  @@map("pagos")
}

enum EstadoCliente {
  ACTIVO
  VENCIDO
}
